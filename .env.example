# Copy this file to .env and fill in real values. Never commit .env itself.

# MySQL database (created in CloudPanel: Databases tab)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=rjp
DB_PASSWORD=
DB_NAME=rjp

# Session cookie signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Port this Node process listens on — must match the App Port configured in CloudPanel
PORT=3090

# Set to "production" on the live server (enables secure, HTTPS-only session cookies)
NODE_ENV=production
