<!DOCTYPE html>
<html lang="kn">
<head>
<%- include('partials/head') %>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

<%- include('partials/header') %>

<section class="join rjp-card-page" style="padding-top:48px;">
  <div class="wrap" style="max-width:900px; text-align:center;">
    <span class="eyebrow">ಡಿಜಿಟಲ್ ಸದಸ್ಯತ್ವ ಕಾರ್ಡ್</span>
    <h2 style="margin-bottom:28px;">ಸದಸ್ಯತ್ವ ಕಾರ್ಡ್</h2>

    <div class="rjp-card-stage" id="rjpCardStage">
      <div class="rjp-card-wrap" id="rjpCardWrap">
        <%- include('partials/membership-card-faces', { member, qrDataUrl, frontId: 'rjpCardFront', backId: 'rjpCardBack', frontActive: true, backActive: false }) %>
      </div>
    </div>

    <div class="rjp-card-actions">
      <button type="button" class="btn btn-ghost" style="color:var(--navy); border-color:var(--line);" id="rjpCardFlip">🔄 Flip to Back</button>
      <button type="button" class="btn btn-ghost" style="color:var(--navy); border-color:var(--line);" id="rjpCardPrint">🖨 Print</button>
      <a class="btn btn-primary" style="color:var(--navy);" href="<%= downloadPdfUrl %>">⬇ Download PDF</a>
      <a class="btn btn-ghost" style="color:var(--navy); border-color:var(--line);" href="<%= backUrl %>">← Back</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script>
  (function () {
    document.getElementById('rjpCardFlip').addEventListener('click', function () {
      document.getElementById('rjpCardFront').classList.toggle('active');
      document.getElementById('rjpCardBack').classList.toggle('active');
      this.textContent = document.getElementById('rjpCardBack').classList.contains('active') ? '🔄 Flip to Front' : '🔄 Flip to Back';
      if (window.rjpFitCardStages) window.rjpFitCardStages();
    });

    document.getElementById('rjpCardPrint').addEventListener('click', function () {
      window.print();
    });
  })();
</script>
</body>
</html>
