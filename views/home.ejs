<!DOCTYPE html>
<html lang="kn">
<head>
<%- include('partials/head') %>
</head>
<body>

<%- include('partials/header') %>

<section class="hero" id="top">
  <% banner.slides.forEach(function(slide, i){ %>
    <img class="slide<%= i===0 ? ' current' : '' %>" src="<%= slide.image %>" alt="<%= slide.alt %>">
  <% }); %>
  <button class="hero-nav prev" aria-label="ಹಿಂದಿನ ಚಿತ್ರ">&#10094;</button>
  <button class="hero-nav next" aria-label="ಮುಂದಿನ ಚಿತ್ರ">&#10095;</button>
  <div class="hero-dots"></div>
</section>
<div class="tricolor-rule"></div>

<section id="about">
  <div class="wrap about-grid">
    <div class="about-copy">
      <span class="eyebrow">RJP ಹುಟ್ಟಿದ ಉದ್ದೇಶ</span>
      <h2>ರಾಜಕೀಯ ಎಂದರೆ ಅಧಿಕಾರವಲ್ಲ — ಅದು ಸೇವೆ</h2>
      <p>ಭ್ರಷ್ಟಾಚಾರ, ಆಡಳಿತದ ವಿಳಂಬ, ಜನ ಮತ್ತು ಸರ್ಕಾರದ ನಡುವಿನ ಅಂತರ — ಇವು ಇಂದಿಗೂ ಜನಸಾಮಾನ್ಯರ ದೈನಂದಿನ ಸವಾಲುಗಳಾಗಿವೆ. ರಾಷ್ಟ್ರೀಯ ಜನಹಿತ ಪಕ್ಷ (RJP) ಜನಸಾಮಾನ್ಯರ ಧ್ವನಿಯಾಗಿ, ಪಾರದರ್ಶಕ ಮತ್ತು ಹೊಣೆಗಾರಿಕೆಯುತ ಆಡಳಿತದ ಗುರಿಯೊಂದಿಗೆ ಸ್ಥಾಪನೆಗೊಂಡ ಪಕ್ಷ.</p>
      <p>ವ್ಯಕ್ತಿಪೂಜೆಗಿಂತ ತತ್ವ, ಅಧಿಕಾರಕ್ಕಿಂತ ಸೇವೆ ಎಂಬ ನಂಬಿಕೆಯೊಂದಿಗೆ ನಾವು ಕಾರ್ಯ ನಿರ್ವಹಿಸುತ್ತೇವೆ.</p>
      <ul class="pillars">
        <li><span class="dot"></span> ರೈತನ ಬದುಕಿಗೆ ಭದ್ರತೆ</li>
        <li><span class="dot"></span> ಯುವಕರ ಕನಸಿಗೆ ಅವಕಾಶ</li>
        <li><span class="dot"></span> ಮಹಿಳೆಯರಿಗೆ ಗೌರವ ಮತ್ತು ಸುರಕ್ಷತೆ</li>
        <li><span class="dot"></span> ಸಾಮಾನ್ಯ ನಾಗರಿಕನಿಗೆ ನ್ಯಾಯ ಮತ್ತು ಘನತೆ</li>
      </ul>
    </div>
    <img src="/images/agenda-poster.jpg" alt="ರೈತ ಮತ್ತು ಯುವಕ ವಿಧಾನಸೌಧದತ್ತ ನಡೆಯುತ್ತಿರುವುದು — RJP ಅಭಿಯಾನ ಪೋಸ್ಟರ್">
  </div>
</section>

<section class="launch section-alt">
  <div class="wrap launch-grid">
    <img src="/images/flag-2.jpg" alt="RJP ಧ್ವಜ ನೀಲಾಕಾಶದಲ್ಲಿ ಹಾರಾಡುತ್ತಿದೆ">
    <div>
      <span class="eyebrow">ಅಧಿಕೃತ ಲೋಕಾರ್ಪಣೆ</span>
      <h2>ಬದಲಾವಣೆಯ ಬಯಸುವಿರಾ? ಬದಲಾವಣೆಯ ಭಾಗವಾಗಿರಿ</h2>
      <p>ರಾಷ್ಟ್ರೀಯ ಜನಹಿತ ಪಕ್ಷದ ಸಾರ್ವಜನಿಕ ಕಾರ್ಯಕ್ರಮಗಳು ಮತ್ತು ಸದಸ್ಯತ್ವ ಅಭಿಯಾನದ ಇತ್ತೀಚಿನ ಮಾಹಿತಿಗಾಗಿ ನಮ್ಮ WhatsApp community ಮತ್ತು ಸಾಮಾಜಿಕ ಮಾಧ್ಯಮ ಪುಟಗಳನ್ನು ಅನುಸರಿಸಿ.</p>
      <div class="launch-meta">
        <div><b>ಸ್ಥಳ</b><span>ನಗರಭವನ ಮೈದಾನ, ಬೆಂಗಳೂರು</span></div>
        <div><b>ಘೋಷ ವಾಕ್ಯ</b><span>ಹೊಸ ಚಿಂತನೆ · ಹೊಸ ರಾಜಕೀಯ · ಹೊಸ ಭವಿಷ್ಯ</span></div>
      </div>
      <a class="btn btn-primary" style="color:var(--white); background:var(--green);" href="/join">ಈಗಲೇ ಸೇರಿ · Join RJP</a>
    </div>
  </div>
</section>

<section id="ideology" class="ideology">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">ನಮ್ಮ ಸಿದ್ಧಾಂತ</span>
      <h2>"ಜನ ಮೊದಲು... ಅಧಿಕಾರ ನಂತರ"</h2>
      <p>ಪ್ರತಿ ನಿರ್ಧಾರದ ಹಿಂದೆ ಇರುವುದು ಒಂದೇ ಪ್ರಶ್ನೆ — ಇದರಿಂದ ಸಾಮಾನ್ಯ ಪ್ರಜೆಗೆ ಏನು ಪ್ರಯೋಜನ?</p>
    </div>
    <div class="ideology-layout">
      <img src="/images/values-poster.jpg" alt="ಒಬ್ಬ ವ್ಯಕ್ತಿಯ ಕನಸಲ್ಲ, ಕೋಟಿ ಜನರ ಆಶಯ — RJP ಪೋಸ್ಟರ್">
      <div class="value-grid">
        <div class="value-card"><div class="num">01</div><p>ಭ್ರಷ್ಟಾಚಾರ ಮುಕ್ತ ಆಡಳಿತ</p></div>
        <div class="value-card"><div class="num">02</div><p>ಪಾರದರ್ಶಕ ಸರ್ಕಾರ</p></div>
        <div class="value-card"><div class="num">03</div><p>ಜನರ ತೆರಿಗೆ ಹಣಕ್ಕೆ ಜನರ ಮುಂದೆ ಲೆಕ್ಕ</p></div>
        <div class="value-card"><div class="num">04</div><p>ಅರ್ಹತೆಗೆ ಅವಕಾಶ, ಶಿಫಾರಸಿಗಲ್ಲ</p></div>
        <div class="value-card"><div class="num">05</div><p>ಜಾತಿ-ಧರ್ಮದ ರಾಜಕೀಯಕ್ಕಿಂತ ಅಭಿವೃದ್ಧಿ ರಾಜಕೀಯ</p></div>
        <div class="value-card"><div class="num">06</div><p>ಶಿಕ್ಷಣ, ಆರೋಗ್ಯ, ಉದ್ಯೋಗಕ್ಕೆ ಮೊದಲ ಆದ್ಯತೆ</p></div>
        <div class="value-card"><div class="num">07</div><p>ರೈತರು, ಕಾರ್ಮಿಕರು, ಮಧ್ಯಮ ವರ್ಗದ ರಕ್ಷಣೆ</p></div>
      </div>
    </div>
  </div>
</section>

<section class="section-alt">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">RJP ಏಕೆ ವಿಭಿನ್ನ?</span>
      <h2>ರಾಜಕೀಯ ಸಂಸ್ಕೃತಿಯ ಬದಲಾವಣೆಗಾಗಿ ಬಂದಿದ್ದೇವೆ</h2>
      <p>ನಾವು ಕೇವಲ ರಾಜಕೀಯ ಬದಲಾವಣೆಗಾಗಿ ಬಂದಿಲ್ಲ — ನಾವು ಬಂದಿರುವುದು ರಾಜಕೀಯ ಸಂಸ್ಕೃತಿ ಬದಲಾವಣೆಗಾಗಿ. ಇಲ್ಲಿ ವ್ಯಕ್ತಿಪೂಜೆಗೆ ಜಾಗವಿಲ್ಲ; ಇರುವುದು ಕೇವಲ ಜನಹಿತದ ಬದ್ಧತೆ.</p>
    </div>
    <div class="difference">
      <div class="seal-card">
        <div class="seal"><span>ತ</span></div>
        <h3>ನಾಯಕನಿಗಿಂತ ತತ್ವ ಮುಖ್ಯ</h3>
        <p>ವ್ಯಕ್ತಿಗಳಲ್ಲ, ಮೌಲ್ಯಗಳೇ ನಮ್ಮ ರಾಜಕೀಯದ ಅಡಿಪಾಯ.</p>
      </div>
      <div class="seal-card">
        <div class="seal"><span>ವ್ಯ</span></div>
        <h3>ವ್ಯಕ್ತಿಗಿಂತ ವ್ಯವಸ್ಥೆ ದೊಡ್ಡದು</h3>
        <p>ಗಟ್ಟಿಯಾದ ವ್ಯವಸ್ಥೆಯೊಂದೇ ದೀರ್ಘಕಾಲೀನ ಬದಲಾವಣೆ ತರುತ್ತದೆ.</p>
      </div>
      <div class="seal-card">
        <div class="seal"><span>ಜ</span></div>
        <h3>ಭರವಸೆಗಿಂತ ಜವಾಬ್ದಾರಿ ಮುಖ್ಯ</h3>
        <p>ಪ್ರತಿ ಜನಪ್ರತಿನಿಧಿಗೂ ವಾರ್ಷಿಕ ಕಾರ್ಯಕ್ಷಮತೆ ವರದಿ ಕಡ್ಡಾಯ.</p>
      </div>
    </div>
  </div>
</section>

<section id="agenda">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">ಹೊಸ ರಾಜಕೀಯ ಅಜೆಂಡಾ</span>
      <h2>ಕಾರ್ಯಸಾಧ್ಯವಾದ, ಸ್ಪಷ್ಟ ಕಾರ್ಯಸೂಚಿ</h2>
    </div>
    <div class="agenda-layout">
      <img src="/images/vision-mission-poster.jpg" alt="RJP ದೃಷ್ಟಿ ಮತ್ತು ಧ್ಯೇಯ ಪೋಸ್ಟರ್">
      <ul class="agenda-list">
        <li>
          <div class="agenda-tag">01</div>
          <div>
            <span class="en">Zero Corruption Governance</span>
            <h4>ಲಂಚ ಮುಕ್ತ ಆಡಳಿತ ವ್ಯವಸ್ಥೆ</h4>
            <p>ಪ್ರತಿ ಸೇವೆಯೂ ಲಂಚ ರಹಿತವಾಗಿ ಸಿಗುವಂತಹ ವ್ಯವಸ್ಥೆ ನಿರ್ಮಾಣ.</p>
          </div>
        </li>
        <li>
          <div class="agenda-tag">02</div>
          <div>
            <span class="en">Digital Transparent Administration</span>
            <h4>ಪಾರದರ್ಶಕ ಡಿಜಿಟಲ್ ಆಡಳಿತ</h4>
            <p>ಪ್ರತಿ ಫೈಲ್, ಪ್ರತಿ ನಿರ್ಧಾರ ಆನ್‌ಲೈನ್‌ನಲ್ಲಿ ಪಾರದರ್ಶಕ.</p>
          </div>
        </li>
        <li>
          <div class="agenda-tag">03</div>
          <div>
            <span class="en">Time Bound Government Services</span>
            <h4>ನಿಗದಿತ ಸಮಯದೊಳಗೆ ಸೇವೆ</h4>
            <p>ಸೇವೆ ವಿಳಂಬವಾದರೆ ಅಧಿಕಾರಿಗಳ ಹೊಣೆಗಾರಿಕೆ ಕಡ್ಡಾಯ.</p>
          </div>
        </li>
        <li>
          <div class="agenda-tag">04</div>
          <div>
            <span class="en">Accountability of Representatives</span>
            <h4>ಜನಪ್ರತಿನಿಧಿಗಳ ಹೊಣೆಗಾರಿಕೆ</h4>
            <p>ಪ್ರತಿ ಜನಪ್ರತಿನಿಧಿಗೂ ವಾರ್ಷಿಕ ಕಾರ್ಯಕ್ಷಮತೆ ವರದಿ.</p>
          </div>
        </li>
        <li>
          <div class="agenda-tag">05</div>
          <div>
            <span class="en">Clean Political Funding</span>
            <h4>ಪಾರದರ್ಶಕ ದೇಣಿಗೆ ವ್ಯವಸ್ಥೆ</h4>
            <p>ಪಕ್ಷದ ಪ್ರತಿ ದೇಣಿಗೆಯೂ ಸಾರ್ವಜನಿಕರ ಮುಂದೆ ದಾಖಲಾಗುತ್ತದೆ.</p>
          </div>
        </li>
        <li>
          <div class="agenda-tag">06</div>
          <div>
            <span class="en">Internal Party Democracy</span>
            <h4>ಪಕ್ಷದೊಳಗೆ ಸ್ವತಂತ್ರ ಚುನಾವಣೆ</h4>
            <p>ನ್ಯಾಯಸಮ್ಮತ, ಸ್ವತಂತ್ರ ಆಂತರಿಕ ಪ್ರಜಾಪ್ರಭುತ್ವ.</p>
          </div>
        </li>
        <li>
          <div class="agenda-tag">07</div>
          <div>
            <span class="en">Youth &amp; Women Leadership</span>
            <h4>ಯುವಕರಿಗೆ ಮತ್ತು ಮಹಿಳೆಯರಿಗೆ ಮುಂಚೂಣಿ ಪಾತ್ರ</h4>
            <p>ನಿರ್ಧಾರ ಕೈಗೊಳ್ಳುವ ವೇದಿಕೆಯಲ್ಲಿ ಯುವಕರು ಮತ್ತು ಮಹಿಳೆಯರಿಗೆ ಆದ್ಯತೆ.</p>
          </div>
        </li>
        <li>
          <div class="agenda-tag">08</div>
          <div>
            <span class="en">Technology Based Governance</span>
            <h4>ತಂತ್ರಜ್ಞಾನ ಆಧಾರಿತ ಜನಸ್ನೇಹಿ ಆಡಳಿತ</h4>
            <p>ಶಿಕ್ಷಣ, ಆರೋಗ್ಯ, ಉದ್ಯೋಗಕ್ಕೆ ಮೊದಲ ಆದ್ಯತೆ ನೀಡುವ ಡಿಜಿಟಲ್ ವ್ಯವಸ್ಥೆ.</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>

<section class="dream">
  <div class="wrap">
    <span class="eyebrow">ನಮ್ಮ ಕನಸಿನ ಕರ್ನಾಟಕ</span>
    <h2>ಇದೇ ನಮ್ಮ ಕನಸು. ಇದೇ ನಮ್ಮ ಬದ್ಧತೆ.</h2>
    <p class="dream-lines">
      <span>ಅಲ್ಲಿ... ಲಂಚವಿಲ್ಲದೆ ಕೆಲಸ ಆಗಬೇಕು.</span>
      <span>ಅಲ್ಲಿ... ಪ್ರತಿಭೆಗೆ ಅವಕಾಶ ಸಿಗಬೇಕು, ಶಿಫಾರಸಿಗಲ್ಲ.</span>
      <span>ಅಲ್ಲಿ... ರೈತ ಗೌರವದಿಂದ ಬದುಕಬೇಕು.</span>
      <span>ಅಲ್ಲಿ... ಯುವಕ ಉದ್ಯೋಗಕ್ಕಾಗಿ ಊರು ಬಿಡುವ ಪರಿಸ್ಥಿತಿ ಕಡಿಮೆಯಾಗಬೇಕು.</span>
      <span>ಅಲ್ಲಿ... ಸಾಮಾನ್ಯ ನಾಗರಿಕನ ಧ್ವನಿ ಅಧಿಕಾರದ ಕೇಂದ್ರಕ್ಕೆ ತಲುಪಬೇಕು.</span>
    </p>
    <p class="dream-quote">"ಒಬ್ಬ ವ್ಯಕ್ತಿಯ ಕನಸಲ್ಲ... ಕೋಟಿ ಜನರ ಆಶಯ"</p>
  </div>
</section>

<section id="wings" class="section-alt">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">ಘಟಕಗಳು</span>
      <h2>ಯುವ ಘಟಕ ಮತ್ತು ಮಹಿಳಾ ಘಟಕ</h2>
    </div>
    <div class="wings">
      <div class="wing-card youth">
        <div class="icon">👦</div>
        <h3>ಯುವ ಘಟಕ</h3>
        <p>ಕರ್ನಾಟಕದ ಭವಿಷ್ಯ ಬರೆಯುವವರು ಇಂದಿನ ಯುವಕರು. RJP ಯುವ ಘಟಕ ಯುವಕರಿಗೆ ನಾಯಕತ್ವ, ತರಬೇತಿ ಮತ್ತು ನಿರ್ಧಾರ ಕೈಗೊಳ್ಳುವ ವೇದಿಕೆ ಒದಗಿಸುತ್ತದೆ.</p>
      </div>
      <div class="wing-card women">
        <div class="icon">👩</div>
        <h3>ಮಹಿಳಾ ಘಟಕ</h3>
        <p>ಮಹಿಳೆಯರ ಸುರಕ್ಷತೆ, ಗೌರವ ಮತ್ತು ನಾಯಕತ್ವ RJP ಯ ಆದ್ಯತೆ. ಮಹಿಳಾ ಘಟಕ ರಾಜಕೀಯದಲ್ಲಿ ಮಹಿಳೆಯರ ಸಶಕ್ತ ಪಾಲ್ಗೊಳ್ಳುವಿಕೆಗೆ ದಾರಿ ಮಾಡಿಕೊಡುತ್ತದೆ.</p>
      </div>
    </div>
  </div>
</section>

<section id="transparency">
  <div class="wrap transparency">
    <div class="transparency-copy">
      <span class="eyebrow">ಪಾರದರ್ಶಕತಾ ನೀತಿ</span>
      <h2>ಪ್ರತಿ ದೇಣಿಗೆ, ಪ್ರತಿ ಖರ್ಚು — ಸಾರ್ವಜನಿಕರ ಮುಂದೆ</h2>
      <p>RJP ಪ್ರತಿ ದೇಣಿಗೆ, ಪ್ರತಿ ಖರ್ಚು, ಪ್ರತಿ ನಿರ್ಧಾರವನ್ನು ಸಾರ್ವಜನಿಕರ ಮುಂದೆ ಪಾರದರ್ಶಕವಾಗಿ ಇಡಲು ಬದ್ಧವಾಗಿದೆ. ಇದೇ ನಮ್ಮ ವಿಶ್ವಾಸಾರ್ಹತೆಯ ಅಡಿಪಾಯ.</p>
      <div class="stat-row">
        <div class="stat"><b>100%</b><span>ಸಾರ್ವಜನಿಕ ಲೆಕ್ಕಪತ್ರ</span></div>
        <div class="stat"><b>0</b><span>ಶಿಫಾರಸು ಆಧಾರಿತ ಹುದ್ದೆ</span></div>
        <div class="stat"><b>ವಾರ್ಷಿಕ</b><span>ಕಾರ್ಯಕ್ಷಮತೆ ವರದಿ</span></div>
      </div>
    </div>
    <div class="transparency-visual">
      <div class="tricolor-rule"></div>
      <h3 style="color:#fff;">ನಮ್ಮ ಬದ್ಧತೆ</h3>
      <ul>
        <li>ಪ್ರತಿಯೊಬ್ಬ ನಾಗರಿಕನಿಗೂ ಪಕ್ಷದ ಲೆಕ್ಕಪತ್ರ ವೀಕ್ಷಿಸುವ ಹಕ್ಕು.</li>
        <li>ಯಾವುದೇ ನಿರ್ಧಾರ ಮುಚ್ಚುಮರೆ ಇಲ್ಲದೆ ಪ್ರಕಟ.</li>
        <li>ಡಿಜಿಟಲ್ ಮೆಂಬರ್‌ಷಿಪ್ ದಾಖಲೆ, QR ಮೂಲಕ ಪರಿಶೀಲನೆ.</li>
      </ul>
    </div>
  </div>
</section>

<section id="join" class="join">
  <div class="wrap join-grid">
    <div class="rjp-card-preview-row">
      <div class="rjp-card-stage">
        <div class="rjp-card-wrap">
          <%- include('partials/membership-card-faces', { member: previewMember, qrDataUrl: previewQrDataUrl, frontActive: true, backActive: false }) %>
        </div>
      </div>
      <div class="rjp-card-stage">
        <div class="rjp-card-wrap">
          <%- include('partials/membership-card-faces', { member: previewMember, qrDataUrl: previewQrDataUrl, frontActive: false, backActive: true }) %>
        </div>
      </div>
    </div>
    <div class="join-copy">
      <span class="eyebrow">ಚಳುವಳಿ ಸೇರಿ</span>
      <h2>ಇದು ಒಂದು ಪಕ್ಷವಲ್ಲ, ಒಂದು ಚಳುವಳಿ</h2>
      <p>ಬದಲಾವಣೆ ಬಯಸುವ ಪ್ರತಿಯೊಬ್ಬ ಪ್ರಜೆಗೂ ಇಲ್ಲಿ ಸ್ಥಾನವಿದೆ. ನಮ್ಮೊಂದಿಗೆ ಕೈಜೋಡಿಸಿ, ಹೊಸ ರಾಜಕೀಯ ಸಂಸ್ಕೃತಿಯ ಭಾಗವಾಗಿ.</p>
      <ul class="join-steps">
        <li>ಸದಸ್ಯತ್ವ ನೋಂದಣಿ ಫಾರ್ಮ್ ಭರ್ತಿ ಮಾಡಿ.</li>
        <li>QR ಕೋಡ್ ಮೂಲಕ ದೃಢೀಕರಿಸಿದ ಡಿಜಿಟಲ್ ಮೆಂಬರ್‌ಷಿಪ್ ಕಾರ್ಡ್ ಪಡೆಯಿರಿ.</li>
        <li>ನಿಮ್ಮ ಕ್ಷೇತ್ರದ RJP ತಂಡದೊಂದಿಗೆ ಸಂಪರ್ಕ ಸಾಧಿಸಿ.</li>
      </ul>
      <div class="hero-cta-row">
        <a class="btn btn-primary" style="color:var(--white); background:var(--green);" href="/register">ಸದಸ್ಯರಾಗಿ</a>
        <a class="btn btn-ghost" style="color:var(--navy); border-color:var(--line);" href="/login">ಈಗಾಗಲೇ ಸದಸ್ಯರೇ? ಲಾಗಿನ್</a>
      </div>
    </div>
  </div>
</section>

<div class="tricolor-rule thin"></div>

