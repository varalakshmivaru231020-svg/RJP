<!DOCTYPE html>
<html lang="kn">
<head>
<%- include('partials/head') %>
</head>
<body>

<%- include('partials/header') %>

<section class="join" style="padding-top:48px;">
  <div class="wrap" style="max-width:420px;">
    <span class="eyebrow">ಸದಸ್ಯ ಲಾಗಿನ್</span>
    <h2 style="margin-bottom:24px;">ಸದಸ್ಯರ ಲಾಗಿನ್</h2>

    <div class="wizard-card">
      <% if (error) { %>
        <p class="form-error"><%= error %></p>
      <% } %>
      <form method="POST" action="/login" class="form-grid" style="grid-template-columns:1fr;">
        <label>ಮೊಬೈಲ್ ಸಂಖ್ಯೆ
          <input type="tel" name="mobile" pattern="[0-9]{10}" maxlength="10" required autofocus>
        </label>
        <label>ಪಾಸ್‌ವರ್ಡ್
          <input type="password" name="password" required>
        </label>
        <p class="form-note" style="margin:-6px 0 6px;">ಪಾಸ್‌ವರ್ಡ್ ಮರೆತಿರಾ? ನಿಮ್ಮ ಬೂತ್ ಸಂಯೋಜಕರನ್ನು ಅಥವಾ <a href="tel:9632527961" style="color:var(--green-deep);">9632527961</a> ಸಂಪರ್ಕಿಸಿ.</p>
        <button type="submit" class="btn btn-primary" style="color:var(--navy); justify-self:start;">ಲಾಗಿನ್</button>
      </form>
    </div>

    <p class="form-note" style="margin-top:18px;">ಇನ್ನೂ ಸದಸ್ಯರಾಗಿಲ್ಲವೇ? <a href="/register" style="color:var(--green-deep); font-weight:600;">ಇಲ್ಲಿ ನೋಂದಣಿ ಮಾಡಿ</a></p>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
