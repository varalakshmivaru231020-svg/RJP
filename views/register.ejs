<!DOCTYPE html>
<html lang="kn">
<head>
<%- include('partials/head') %>
</head>
<body>

<%- include('partials/header') %>

<section id="register" class="join" style="padding-top:48px;">
  <div class="wrap" style="max-width:820px;">
    <span class="eyebrow">ಚಳುವಳಿ ಸೇರಿ</span>
    <h2 style="margin-bottom:28px;">ಸದಸ್ಯತ್ವ ನೋಂದಣಿ ಫಾರ್ಮ್</h2>

    <div class="wizard-card">
      <ol class="wizard-steps" id="wizardSteps">
        <li class="active" data-step="1"><span class="num">1</span> ವೈಯಕ್ತಿಕ ವಿವರ</li>
        <li data-step="2"><span class="num">2</span> ರಾಜಕೀಯ ವಿವರ</li>
        <li data-step="3"><span class="num">3</span> ಹೆಚ್ಚುವರಿ ವಿವರ</li>
      </ol>

      <% if (error) { %>
        <p class="form-error"><%= error %></p>
      <% } %>

      <form id="registerForm" method="POST" action="/register" enctype="multipart/form-data" novalidate>

        <div class="wizard-panel active" data-panel="1">
          <div class="form-grid">
            <label>ಪೂರ್ಣ ಹೆಸರು *
              <input type="text" name="fullName" value="<%= old.fullName %>" required>
            </label>
            <label>ತಂದೆ/ತಾಯಿಯ ಹೆಸರು
              <input type="text" name="guardianName" value="<%= old.guardianName %>">
            </label>
            <label>ಹುಟ್ಟಿದ ದಿನಾಂಕ
              <input type="date" name="dob" value="<%= old.dob %>">
            </label>
            <label>ಲಿಂಗ
              <select name="gender">
                <option value="">ಆಯ್ಕೆಮಾಡಿ</option>
                <option value="Male" <%= old.gender==='Male' ? 'selected' : '' %>>ಪುರುಷ</option>
                <option value="Female" <%= old.gender==='Female' ? 'selected' : '' %>>ಮಹಿಳೆ</option>
                <option value="Other" <%= old.gender==='Other' ? 'selected' : '' %>>ಇತರೆ</option>
              </select>
            </label>
            <label>ಮೊಬೈಲ್ ಸಂಖ್ಯೆ *
              <input type="tel" name="mobile" pattern="[0-9]{10}" maxlength="10" placeholder="10 ಅಂಕಿಗಳ ಸಂಖ್ಯೆ" value="<%= old.mobile %>" required>
            </label>
            <label>WhatsApp ಸಂಖ್ಯೆ
              <input type="tel" name="whatsapp" pattern="[0-9]{10}" maxlength="10" value="<%= old.whatsapp %>">
            </label>
            <label>ಇಮೇಲ್
              <input type="email" name="email" value="<%= old.email %>">
            </label>
            <label>ಆಧಾರ್ ಸಂಖ್ಯೆ
              <input type="text" name="aadhaar" pattern="[0-9]{12}" maxlength="12" placeholder="12 ಅಂಕಿಗಳ ಸಂಖ್ಯೆ" value="<%= old.aadhaar %>">
            </label>
            <label class="span-2">ವಿಳಾಸ
              <textarea name="address" rows="3"><%= old.address %></textarea>
            </label>
            <label>ಪಾಸ್‌ವರ್ಡ್ ರಚಿಸಿ *
              <input type="password" name="password" minlength="6" required autocomplete="new-password">
            </label>
            <label>ಪಾಸ್‌ವರ್ಡ್ ಖಚಿತಪಡಿಸಿ *
              <input type="password" name="confirmPassword" minlength="6" required autocomplete="new-password">
            </label>
          </div>
          <p class="form-note">ಈ ಪಾಸ್‌ವರ್ಡ್ ಮತ್ತು ನಿಮ್ಮ ಮೊಬೈಲ್ ಸಂಖ್ಯೆಯನ್ನು ಬಳಸಿ ಮುಂದೆ ಸದಸ್ಯರ ಲಾಗಿನ್‌ಗೆ ಪ್ರವೇಶಿಸಬಹುದು.</p>
          <div class="wizard-actions">
            <span></span>
            <button type="button" class="btn btn-primary wizard-next">ಮುಂದೆ →</button>
          </div>
        </div>

        <div class="wizard-panel" data-panel="2">
          <div class="form-grid">
            <label>ರಾಜ್ಯ
              <input type="text" name="state" value="<%= old.state || 'Karnataka' %>">
            </label>
            <label>ಜಿಲ್ಲೆ
              <select name="district" id="districtSelect">
                <option value="">ಆಯ್ಕೆಮಾಡಿ</option>
                <% districts.forEach(function(d){ %>
                  <option value="<%= d %>" <%= old.district===d ? 'selected' : '' %>><%= d %></option>
                <% }); %>
              </select>
            </label>
            <label>ತಾಲೂಕು
              <select name="taluk" id="talukSelect" data-selected="<%= old.taluk %>">
                <option value="">ಮೊದಲು ಜಿಲ್ಲೆ ಆಯ್ಕೆಮಾಡಿ</option>
              </select>
            </label>
            <label>ವಿಧಾನಸಭಾ ಕ್ಷೇತ್ರ
              <input type="text" name="assembly" value="<%= old.assembly %>">
            </label>
            <label>ಲೋಕಸಭಾ ಕ್ಷೇತ್ರ
              <input type="text" name="parliament" value="<%= old.parliament %>">
            </label>
            <label>ವಾರ್ಡ್
              <input type="text" name="ward" value="<%= old.ward %>">
            </label>
            <label>ಬೂತ್ ಸಂಖ್ಯೆ
              <input type="text" name="booth" value="<%= old.booth %>">
            </label>
          </div>
          <div class="wizard-actions">
            <button type="button" class="btn btn-ghost wizard-prev" style="color:var(--navy); border-color:var(--line);">← ಹಿಂದೆ</button>
            <button type="button" class="btn btn-primary wizard-next">ಮುಂದೆ →</button>
          </div>
        </div>

        <div class="wizard-panel" data-panel="3">
          <div class="form-grid">
            <label>ಉದ್ಯೋಗ
              <input type="text" name="occupation" value="<%= old.occupation %>">
            </label>
            <label>ವಿದ್ಯಾರ್ಹತೆ
              <input type="text" name="education" value="<%= old.education %>">
            </label>
            <label>ಧರ್ಮ
              <input type="text" name="religion" value="<%= old.religion %>">
            </label>
            <label>ಜಾತಿ
              <input type="text" name="caste" value="<%= old.caste %>">
            </label>
            <label>ಉಪಜಾತಿ
              <input type="text" name="subCaste" value="<%= old.subCaste %>">
            </label>
            <label>ಸಾಮಾಜಿಕ ಮಾಧ್ಯಮ (ಐಚ್ಛಿಕ)
              <input type="text" name="socialMedia" placeholder="Instagram / Facebook handle" value="<%= old.socialMedia %>">
            </label>
          </div>

          <fieldset class="form-fieldset">
            <legend>ಆಸಕ್ತಿಯ ಕ್ಷೇತ್ರಗಳು</legend>
            <div class="checkbox-grid">
              <% interests.forEach(function(i){ %>
                <label class="checkbox-item">
                  <input type="checkbox" name="areasOfInterest" value="<%= i %>" <%= old.areasOfInterest.includes(i) ? 'checked' : '' %>>
                  <%= i %>
                </label>
              <% }); %>
            </div>
          </fieldset>

          <div class="form-grid" style="margin-top:20px;">
            <label>ಫೋಟೋ ಅಪ್‌ಲೋಡ್ <span class="hint">(JPG/PNG, 3MB ವರೆಗೆ)</span>
              <input type="file" name="photo" accept=".jpg,.jpeg,.png">
            </label>
            <label>ಗುರುತಿನ ಚೀಟಿ ಅಪ್‌ಲೋಡ್ <span class="hint">(ಆಧಾರ್/ವೋಟರ್ ಐಡಿ, JPG/PNG/PDF)</span>
              <input type="file" name="idUpload" accept=".jpg,.jpeg,.png,.pdf">
            </label>
          </div>

          <fieldset class="form-fieldset" style="margin-top:20px;">
            <legend>ಸದಸ್ಯತ್ವ ಶುಲ್ಕ ಮತ್ತು ದೇಣಿಗೆ</legend>

            <div class="fee-row">
              <div>
                <div class="fee-label">ಸದಸ್ಯತ್ವ ಶುಲ್ಕ *</div>
                <div class="fee-caption">ಎಲ್ಲಾ ಸದಸ್ಯರಿಗೂ ಕಡ್ಡಾಯ</div>
              </div>
              <div class="fee-amount">₹<%= paymentFee %></div>
            </div>

            <div class="donation-section">
              <div class="donation-section-title">ಐಚ್ಛಿಕ ದೇಣಿಗೆ</div>
              <label class="checkbox-item">
                <input type="checkbox" name="donationEnabled" id="donationEnabled" <%= old.donationEnabled ? 'checked' : '' %>>
                ರಾಷ್ಟ್ರೀಯ ಜನಹಿತ ಪಕ್ಷವನ್ನು ಬೆಂಬಲಿಸಲು ನಾನು ಹೆಚ್ಚುವರಿ ದೇಣಿಗೆ ನೀಡಲು ಬಯಸುತ್ತೇನೆ.
              </label>
              <div class="form-grid" id="donationAmountWrap" style="margin-top:14px; <%= old.donationEnabled ? '' : 'display:none;' %>">
                <label class="span-2">ದೇಣಿಗೆ ಮೊತ್ತ
                  <input type="number" name="donationAmount" id="donationAmount" min="<%= donationMin %>" step="1"
                         value="<%= old.donationAmount %>" placeholder="0">
                  <span class="hint">ಕನಿಷ್ಠ ದೇಣಿಗೆ: ₹<%= donationMin %></span>
                </label>
              </div>
            </div>

            <div class="amount-summary">
              <div class="amount-summary-title">ಮೊತ್ತದ ಸಾರಾಂಶ</div>
              <div class="amount-summary-row">
                <span>ಸದಸ್ಯತ್ವ ಶುಲ್ಕ</span>
                <span>₹<%= paymentFee %></span>
              </div>
              <div class="amount-summary-row">
                <span>ಹೆಚ್ಚುವರಿ ದೇಣಿಗೆ</span>
                <span>₹<span id="regDonationLine">0</span></span>
              </div>
              <div class="amount-summary-row total">
                <span>ಒಟ್ಟು ಪಾವತಿಸಬೇಕಾದ ಮೊತ್ತ</span>
                <span>₹<span id="regTotalAmount"><%= paymentFee %></span></span>
              </div>
            </div>

            <div style="margin-top:18px; border-top:1px solid var(--line); padding-top:16px;">
              <p class="form-note" style="margin-top:0; margin-bottom:8px; font-weight:600; color:var(--navy);">ಬ್ಯಾಂಕ್ / UPI ವಿವರಗಳು</p>
              <div class="contact-grid" style="gap:28px; align-items:center;">
                <ul class="contact-list" style="margin:0;">
                  <li><span class="ic">🏦</span> Rashtriya Janahita Party</li>
                  <li><span class="ic">🏛️</span> City Union Bank — Vidyaranyapura Branch</li>
                  <li><span class="ic">💳</span> Current Account: 510909010169682</li>
                  <li><span class="ic">🔢</span> IFSC: CIUB0000567</li>
                  <li><span class="ic">📲</span> UPI ID: EZE0437212@CUB</li>
                </ul>

                <div style="text-align:center;">
                  <img src="/images/party-payment-qr.jpg" alt="RJP Scan & Pay QR code — City Union Bank" style="max-width:220px; width:100%; border-radius:12px; border:1px solid var(--line);">
                  <p class="form-note">ಯಾವುದೇ UPI ಆ್ಯಪ್ (GPay, PhonePe, Paytm) ಮೂಲಕ ಸ್ಕ್ಯಾನ್ ಮಾಡಿ ಪಾವತಿಸಿ.</p>
                </div>
              </div>

              <div class="form-grid" style="margin-top:16px;">
                <label class="span-2">ಪಾವತಿ ಪುರಾವೆ ಅಪ್‌ಲೋಡ್ ಮಾಡಿ * <span class="hint">(ಪಾವತಿಯ ಸ್ಕ್ರೀನ್‌ಶಾಟ್/ರಶೀದಿ — JPG/PNG/PDF)</span>
                  <input type="file" name="paymentProof" accept=".jpg,.jpeg,.png,.pdf" required>
                </label>
              </div>
              <p class="form-note" style="font-weight:600; color:var(--navy);">ಮೇಲಿನ ವಿವರಗಳ ಮೂಲಕ ಪಾವತಿಸಿ, ಪುರಾವೆ ಅಪ್‌ಲೋಡ್ ಮಾಡಿದ ನಂತರವೇ ಅರ್ಜಿ ಸಲ್ಲಿಸಿ.</p>
            </div>
          </fieldset>

          <label class="checkbox-item declaration">
            <input type="checkbox" name="declaration" value="yes" required>
            ನಾನು ನೀಡಿದ ಎಲ್ಲಾ ಮಾಹಿತಿ ನಿಜವೆಂದು ಹಾಗೂ ಸರಿಯಾಗಿದೆ ಎಂದು ಘೋಷಿಸುತ್ತೇನೆ ಮತ್ತು ರಾಷ್ಟ್ರೀಯ ಜನಹಿತ ಪಕ್ಷದ ಸಿದ್ಧಾಂತಗಳನ್ನು ಒಪ್ಪುತ್ತೇನೆ. *
          </label>

          <div class="wizard-actions">
            <button type="button" class="btn btn-ghost wizard-prev" style="color:var(--navy); border-color:var(--line);">← ಹಿಂದೆ</button>
            <button type="submit" class="btn btn-primary">ಸಲ್ಲಿಸಿ</button>
          </div>
        </div>

      </form>
    </div>

    <p class="form-note" style="margin-top:18px;">ಈಗಾಗಲೇ ಸದಸ್ಯರೇ? <a href="/login" style="color:var(--green-deep); font-weight:600;">ಇಲ್ಲಿ ಲಾಗಿನ್ ಮಾಡಿ</a></p>
  </div>
</section>

<%- include('partials/footer') %>
<script>window.RJP_TALUKS = <%- JSON.stringify(taluks) %>;</script>
<script src="/js/register.js"></script>
<script>
  (function () {
    var fee = <%= paymentFee %>;
    var min = <%= donationMin %>;
    var checkbox = document.getElementById('donationEnabled');
    var amountWrap = document.getElementById('donationAmountWrap');
    var amountInput = document.getElementById('donationAmount');
    var totalEl = document.getElementById('regTotalAmount');
    var donationLineEl = document.getElementById('regDonationLine');

    function recalc() {
      var donation = 0;
      if (checkbox.checked) {
        amountWrap.style.display = '';
        var val = parseInt(amountInput.value, 10);
        donation = Number.isFinite(val) && val >= min ? val : 0;
      } else {
        amountWrap.style.display = 'none';
      }
      donationLineEl.textContent = donation;
      totalEl.textContent = fee + donation;
    }

    checkbox.addEventListener('change', recalc);
    amountInput.addEventListener('input', recalc);
    recalc();
  })();
</script>
</body>
</html>
