<%
  const navActive = typeof active !== 'undefined' ? active : 'dashboard';
  const navActivity = typeof activity !== 'undefined' ? activity : [];
%>
<header class="mp-topbar">
  <button class="mp-menu-btn" id="mpMenuBtn" aria-label="Menu">☰</button>
  <a class="mp-topbar-brand" href="/dashboard">
    <img src="/images/logo.jpg" alt="RJP">
    <b>RJP Member Portal</b>
  </a>
  <div class="mp-topbar-actions">
    <a class="mp-bell" href="/dashboard/notifications" aria-label="Notifications">
      🔔
      <% if (navActivity.length) { %><span class="dot"></span><% } %>
    </a>
    <a class="mp-profile-btn" id="mpProfileBtn" href="/dashboard/profile" aria-label="My Profile">
      <% if (member.photo_path) { %>
        <img class="mp-avatar" src="/my-photo" alt="<%= member.full_name %>">
      <% } else { %>
        <span class="mp-avatar"><%= member.full_name.charAt(0) %></span>
      <% } %>
    </a>
  </div>
</header>

<div class="mp-shell">
  <aside class="mp-sidebar">
    <div class="mp-sidebar-profile">
      <% if (member.photo_path) { %>
        <img class="mp-sidebar-avatar" src="/my-photo" alt="<%= member.full_name %>">
      <% } else { %>
        <div class="mp-sidebar-avatar"><%= member.full_name.charAt(0) %></div>
      <% } %>
      <b><%= member.full_name %></b>
      <span><%= member.mobile %></span>
    </div>
    <nav>
      <a href="/dashboard" class="<%= navActive === 'dashboard' ? 'active' : '' %>">📊 Dashboard</a>
      <a href="/dashboard/profile" class="<%= navActive === 'profile' ? 'active' : '' %>">👤 My Profile</a>
      <a href="/dashboard/card" class="<%= navActive === 'card' ? 'active' : '' %>">🪪 Membership Card</a>
      <a href="/dashboard/notifications" class="<%= navActive === 'notifications' ? 'active' : '' %>">📢 Notifications</a>
      <form method="POST" action="/logout"><button type="submit">🚪 Logout</button></form>
    </nav>
  </aside>

  <main class="mp-main">
