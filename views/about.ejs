<!DOCTYPE html>
<html lang="kn">
<head>
<%- include('partials/head') %>
</head>
<body>

<%- include('partials/header') %>

<section id="about" style="padding-top:48px;">
  <div class="wrap about-grid">
    <div class="about-copy">
      <span class="eyebrow">RJP ಹುಟ್ಟಿದ ಉದ್ದೇಶ</span>
      <h2>ರಾಜಕೀಯ ಎಂದರೆ ಅಧಿಕಾರವಲ್ಲ — ಅದು ಸೇವೆ</h2>
      <p>ಭ್ರಷ್ಟಾಚಾರ, ಆಡಳಿತದ ವಿಳಂಬ, ಜನ ಮತ್ತು ಸರ್ಕಾರದ ನಡುವಿನ ಅಂತರ — ಇವು ಇಂದಿಗೂ ಜನಸಾಮಾನ್ಯರ ದೈನಂದಿನ ಸವಾಲುಗಳಾಗಿವೆ. ರಾಷ್ಟ್ರೀಯ ಜನಹಿತ ಪಕ್ಷ (RJP) ಜನಸಾಮಾನ್ಯರ ಧ್ವನಿಯಾಗಿ, ಪಾರದರ್ಶಕ ಮತ್ತು ಹೊಣೆಗಾರಿಕೆಯುತ ಆಡಳಿತದ ಗುರಿಯೊಂದಿಗೆ ಸ್ಥಾಪನೆಗೊಂಡ ಪಕ್ಷ.</p>
      <p>ವ್ಯಕ್ತಿಪೂಜೆಗಿಂತ ತತ್ವ, ಅಧಿಕಾರಕ್ಕಿಂತ ಸೇವೆ ಎಂಬ ನಂಬಿಕೆಯೊಂದಿಗೆ ನಾವು ಕಾರ್ಯ ನಿರ್ವಹಿಸುತ್ತೇವೆ.</p>
      <ul class="pillars">
        <li><span class="dot"></span> ರೈತನ ಬದುಕಿಗೆ ಭದ್ರತೆ</li>
        <li><span class="dot"></span> ಯುವಕರ ಕನಸಿಗೆ ಅವಕಾಶ</li>
        <li><span class="dot"></span> ಮಹಿಳೆಯರಿಗೆ ಗೌರವ ಮತ್ತು ಸುರಕ್ಷತೆ</li>
        <li><span class="dot"></span> ಸಾಮಾನ್ಯ ನಾಗರಿಕನಿಗೆ ನ್ಯಾಯ ಮತ್ತು ಘನತೆ</li>
      </ul>
    </div>
    <img src="/images/agenda-poster.jpg" alt="ರೈತ ಮತ್ತು ಯುವಕ ವಿಧಾನಸೌಧದತ್ತ ನಡೆಯುತ್ತಿರುವುದು — RJP ಅಭಿಯಾನ ಪೋಸ್ಟರ್">
  </div>
</section>

<section class="leader-spotlight">
  <div class="wrap leader-grid">
    <img class="leader-photo" src="/images/veerendrababu-nanjegowda.jpg" alt="Adv. Veerendrababu Nanjegowda — ವೀರೇಂದ್ರಬಾಬು ನಂಜೇಗೌಡ">
    <div class="leader-copy">
      <span class="eyebrow">ಕರ್ನಾಟಕ ರಾಜ್ಯಾಧ್ಯಕ್ಷರು</span>
      <h2 class="leader-name-en">Adv. Veerendrababu Nanjegowda</h2>
      <p class="leader-name-kn">ವೀರೇಂದ್ರಬಾಬು ನಂಜೇಗೌಡ</p>
      <p class="leader-credentials">MBA • LLB • PhD (Pursuing)</p>
      <blockquote class="leader-quote">"A relentless guardian of justice, a storyteller of truth, and a voice that echoes across courtrooms and culture alike."</blockquote>
      <a class="btn btn-ghost" style="color:var(--navy); border-color:var(--line);" href="/karnataka-president">ಪೂರ್ಣ ಪ್ರೊಫೈಲ್ ಓದಿ →</a>
    </div>
  </div>
</section>

<section class="launch section-alt">
  <div class="wrap launch-grid">
    <img src="/images/launch-poster.jpg" alt="RJP ಅಧಿಕೃತ ಲೋಕಾರ್ಪಣೆ ಲಾಂಚ್ ಪೋಸ್ಟರ್">
    <div>
      <span class="eyebrow">ಅಧಿಕೃತ ಲೋಕಾರ್ಪಣೆ</span>
      <h2>ಬದಲಾವಣೆಯ ಬಯಸುವಿರಾ? ಬದಲಾವಣೆಯ ಭಾಗವಾಗಿರಿ</h2>
      <p>ರಾಷ್ಟ್ರೀಯ ಜನಹಿತ ಪಕ್ಷದ ಸಾರ್ವಜನಿಕ ಕಾರ್ಯಕ್ರಮಗಳು ಮತ್ತು ಸದಸ್ಯತ್ವ ಅಭಿಯಾನದ ಇತ್ತೀಚಿನ ಮಾಹಿತಿಗಾಗಿ ನಮ್ಮ WhatsApp community ಮತ್ತು ಸಾಮಾಜಿಕ ಮಾಧ್ಯಮ ಪುಟಗಳನ್ನು ಅನುಸರಿಸಿ.</p>
      <div class="launch-meta">
        <div><b>ಸ್ಥಳ</b><span>ನಗರಭವನ ಮೈದಾನ, ಬೆಂಗಳೂರು</span></div>
        <div><b>ಘೋಷ ವಾಕ್ಯ</b><span>ಹೊಸ ಚಿಂತನೆ · ಹೊಸ ರಾಜಕೀಯ · ಹೊಸ ಭವಿಷ್ಯ</span></div>
      </div>
      <a class="btn btn-primary" style="color:var(--white); background:var(--green);" href="/join">ಈಗಲೇ ಸೇರಿ · Join RJP</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
